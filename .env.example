# ── Auth ───────────────────────────────────────────────────────────────────────
# Mot de passe de connexion (mono-user, jamais stocké en base)
AUTH_PASSWORD=change-me

# Secret JWT — générer avec : openssl rand -base64 32
AUTH_SECRET=change-me-32-chars-minimum

# ── MongoDB ────────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas free tier or local mongod)
MONGODB_URI=mongodb://localhost:27017/prospector

# Pushover (https://pushover.net) — créer une app, récupérer token + user key
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Secret partagé entre le cron OS et /api/cron/run-reminders
CRON_SECRET=change-me

# URL publique utilisée dans les liens des pushs Pushover (vers la fiche prospect)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optionnel : désactive le worker node-cron interne (si tu pilotes tout via cron OS)
# DISABLE_INTERNAL_CRON=1
